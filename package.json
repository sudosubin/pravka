{
  "name": "pravka",
  "version": "0.1.2",
  "private": true,
  "description": "Iosevka 34.6.3 custom build targeting PragmataPro",
  "type": "module",
  "bin": {
    "pravka": "src/cli.ts"
  },
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write .",
    "postinstall": "simple-git-hooks",
    "test": "bun test"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run nano-staged --bail"
  },
  "nano-staged": {
    "*.{ts,js,json,jsonc}": "biome check --write",
    "package.json": "sort-package-json"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.55",
    "@stricli/core": "^1.2.7",
    "@zip.js/zip.js": "^2.8.26",
    "es-toolkit": "^1.47.1",
    "opentype.js": "^1.3.4",
    "sharp": "^0.33.0",
    "smol-toml": "^1.3.0",
    "ssim.js": "^3.5.0",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/opentype.js": "^1.3.8",
    "bun-types": "^1.1.0",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "sort-package-json": "^3.3.0"
  }
}
